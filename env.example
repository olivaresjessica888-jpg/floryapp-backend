# Copia este archivo como ".env" y pega tu clave real de Google Gemini aquí.
# Consíguela GRATIS en https://aistudio.google.com -> "Get API Key"
# NUNCA subas el archivo ".env" real a GitHub ni lo compartas con nadie.
GEMINI_API_KEY=tu-clave-de-gemini-aqui

# Opcional: cambia el modelo si Google lanza una versión más nueva
# GEMINI_MODEL=gemini-2.0-flash
